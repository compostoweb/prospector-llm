{
  "name": "prospector",
  "version": "0.1.0",
  "private": true,
  "description": "Prospector — monorepo scripts (frontend Next.js + backend FastAPI)",
  "scripts": {
    "frontend": "npm run dev --prefix frontend",
    "backend": "cd backend && python -m uvicorn api.main:app --reload --port 8000",
    "dev": "concurrently --kill-others-on-fail --names \"API,WEB\" --prefix-colors \"cyan,magenta\" \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
