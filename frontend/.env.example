# ============================================================
# PROSPECTOR FRONTEND — Template de variáveis
# Copie para .env.local — nunca commitar .env.local
# Em prod: configure direto no painel do Vercel
# ============================================================

# ============================================================
# BACKEND API (Next.js consome o backend em backend/)
# Dev:  http://localhost:8000
# Prod: https://api.seudominio.com.br
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/events
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Variável server-side (não exposta ao browser)
# Usada em Server Components e Server Actions
API_URL=http://localhost:8000

# ============================================================
# NEXTAUTH
# Gere NEXTAUTH_SECRET com: openssl rand -base64 32
# ============================================================
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# NODE
# ============================================================
NODE_ENV=development

# ============================================================
# NOTA SOBRE GOOGLE OAUTH
# O Google OAuth é gerenciado 100% pelo backend (backend/).
# O frontend NÃO precisa de GOOGLE_CLIENT_ID nem GOOGLE_CLIENT_SECRET.
# O callback do Google aponta para: {API_URL}/auth/google/callback
# Configure as credenciais Google no backend/.env.dev
# ============================================================
