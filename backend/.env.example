# ============================================================
# PROSPECTOR — Template de variáveis de ambiente
# Copie para .env.dev (desenvolvimento) e .env.prod (produção)
# NUNCA commitar .env.dev ou .env.prod
# ============================================================

# Ambiente ativo: dev | prod
ENV=dev

# ============================================================
# BANCO DE DADOS REMOTO
# Dev:  postgresql+asyncpg://user:pass@host/prospector_dev
# Prod: postgresql+asyncpg://user:pass@host/prospector_prod
# Provedores recomendados: Neon (neon.tech) ou Supabase
# ============================================================
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/prospector_dev

# ============================================================
# REDIS (local em dev, container no prod)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# APP
# ============================================================
SECRET_KEY=troque-por-string-aleatoria-longa-min-32-chars
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# URL pública da API — usada para gerar links de áudio em voice notes enviados ao Unipile
# Dev: http://localhost:8000  |  Prod: https://api.seudominio.com.br
API_PUBLIC_URL=http://localhost:8000
# URL pública do frontend usada em redirects pós-login
# Dev: http://localhost:3000  |  Prod: https://app.seudominio.com.br
FRONTEND_URL=http://localhost:3000

# ============================================================
# GOOGLE OAUTH — Login humano via Google para painel admin
# Crie um projeto em: https://console.cloud.google.com/
#   1. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   2. Application type: Web application
#   3. Authorized redirect URIs: adicione GOOGLE_REDIRECT_URI abaixo
#
# Apenas emails cadastrados na tabela `users` podem logar.
# O superadmin (SUPERUSER_EMAIL) é criado automaticamente no startup.
# ============================================================
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_EXTENSION_REDIRECT_URI=http://localhost:8000/auth/extension/google/callback
# E-mail do admin master — criado automaticamente se não existir na tabela users
SUPERUSER_EMAIL=adriano@compostoweb.com.br

# ============================================================
# EXTENSAO DO NAVEGADOR — LinkedIn Capture V1
# Kill switch + allowlist de extension IDs por ambiente
# EXTENSION_ALLOWED_IDS aceita lista separada por vírgula
# ============================================================
EXTENSION_LINKEDIN_CAPTURE_ENABLED=false
EXTENSION_CAPTURE_DAILY_LIMIT=250
EXTENSION_ALLOWED_IDS=

# ============================================================
# LLM — PROVEDORES (configure ao menos um)
# Ambos podem coexistir — a escolha é feita por cadência
# A lista de modelos disponíveis vem de: GET /llm/models
# ============================================================

# --- OpenAI ---
# Obrigatório se qualquer cadência usar llm_provider=openai
OPENAI_API_KEY=sk-...
# Modelo padrão global — sobrescrito por cadência individualmente
# Exemplos: gpt-4o-mini (econômico) | gpt-4o | gpt-4.1 | gpt-4.1-nano
OPENAI_DEFAULT_MODEL=gpt-5.1-mini

# --- Google Gemini ---
# Obrigatório se qualquer cadência usar llm_provider=gemini
# Obtenha a key em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...
# Modelo padrão global — sobrescrito por cadência individualmente
# Exemplos: gemini-2.5-flash | gemini-2.5-pro | gemini-2.5-flash-lite
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# --- Anthropic Claude ---
# Obrigatório se qualquer cadência usar llm_provider=anthropic
# Obtenha a key em: https://platform.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Modelo padrão global — sobrescrito por cadência individualmente
# Exemplos: claude-sonnet-4-6 | claude-haiku-4-5 | claude-opus-4-6
# Batch API (50% desconto): usar via POST /leads/analyze-batch
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# --- Reply Parser (fallback legado) ---
# Os fluxos ativos resolvem o provider/modelo pelo tenant; estes campos só
# servem como compatibilidade caso algum ponto ainda não tenha sido migrado.
# Recomendado: gpt-4o-mini (JSON mode confiável, econômico)
# Alternativa:  gemini-2.5-flash (também tem JSON mode nativo)
REPLY_PARSER_PROVIDER=openai
REPLY_PARSER_MODEL=gpt-4o-mini

# ============================================================
# VOZ — provedor de TTS para LinkedIn DM voice notes
# Opções: speechify | openai | playht
# ============================================================
VOICE_PROVIDER=speechify

# Speechify SIMBA ($10/1M chars — recomendado, melhor custo/qualidade)
SPEECHIFY_API_KEY=...
SPEECHIFY_VOICE_ID=...

# OpenAI TTS (usa OPENAI_API_KEY acima)
# OPENAI_TTS_VOICE=alloy

# PlayHT (alternativa)
# PLAYHT_API_KEY=...
# PLAYHT_USER_ID=...
# PLAYHT_VOICE_ID=...

# ============================================================
# UNIPILE — LinkedIn + Gmail
# Docs: https://developer.unipile.com
# Plano base: $55/mês para até 10 contas
# ============================================================
UNIPILE_API_KEY=...
UNIPILE_BASE_URL=https://api2.unipile.com:13246/api/v1
UNIPILE_ACCOUNT_ID_LINKEDIN=...
UNIPILE_ACCOUNT_ID_GMAIL=...
UNIPILE_WEBHOOK_SECRET=...

# ============================================================
# APIFY — captação de leads
# Free: $5 créditos/mês | Starter: $39/mês
# ============================================================
APIFY_API_TOKEN=...
APIFY_ACTOR_GOOGLE_MAPS=compass/crawler-google-places
APIFY_ACTOR_LINKEDIN=dev_fusion/linkedin-profile-scraper

# ============================================================
# EMAIL FINDER — cascata gratuita
# Ordem: Unipile profile → Prospeo → Hunter → Apollo → OSINT
# ============================================================
PROSPEO_API_KEY=...
HUNTER_API_KEY=...
APOLLO_API_KEY=...
ZEROBOUNCE_API_KEY=...

# ============================================================
# CONTEXTO DO LEAD (free tiers para MVP)
# ============================================================
JINA_API_KEY=...
FIRECRAWL_API_KEY=...
TAVILY_API_KEY=...

# ============================================================
# PIPEDRIVE
# ============================================================
PIPEDRIVE_API_TOKEN=...
PIPEDRIVE_DOMAIN=compostoweb
PIPEDRIVE_STAGE_INTEREST=1
PIPEDRIVE_STAGE_OBJECTION=2
PIPEDRIVE_OWNER_ID=1
PIPEDRIVE_NOTIFY_EMAIL=adriano@compostoweb.com.br

# ============================================================
# RESEND — notificações por email
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=Composto Web <site@compostoweb.com.br>
CONTENT_CALCULATOR_NOTIFY_EMAIL=adriano@compostoweb.com.br
CONTENT_CALCULATOR_NOTIFY_FROM_EMAIL=site@compostoweb.com.br
CONTENT_CALCULATOR_REPLY_TO_EMAIL=contato@compostoweb.com.br

# ============================================================
# RATE LIMITS DIÁRIOS POR CANAL
# ============================================================
LIMIT_LINKEDIN_CONNECT=20
LIMIT_LINKEDIN_DM=40
LIMIT_EMAIL=300

# ============================================================
# CELERY
# ============================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================================
# FLOWER (monitoramento workers — prod)
# ============================================================
FLOWER_USER=admin
FLOWER_PASSWORD=troque-aqui

# ============================================================
# CONTENT HUB  LinkedIn OAuth (Share on LinkedIn)
# ============================================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/content/linkedin/callback

# ============================================================
# CONTENT HUB — Inbound / Lead Magnets (SendPulse + páginas públicas)
# Use API key OU OAuth client credentials.
# Base pública do frontend para gerar links como /lm/{slug}
# ============================================================
SENDPULSE_API_KEY=
SENDPULSE_CLIENT_ID=
SENDPULSE_CLIENT_SECRET=
SENDPULSE_WEBHOOK_SECRET=
SENDPULSE_BASE_URL=https://api.sendpulse.com
CONTENT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================================
# CONTENT HUB -- LinkedIn OAuth (Share on LinkedIn)
# ============================================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/content/linkedin/callback

